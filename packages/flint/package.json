    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@standard-schema/spec": "1.0.0"
  },
  "devDependencies": {
    "tsup": "8.3.5",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
